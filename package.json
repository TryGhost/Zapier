{
  "name": "ghost-zapier",
  "version": "2.6.3",
  "description": "Ghost integration for the Zapier platform.",
  "repository": "TryGhost/Zapier",
  "homepage": "https://ghost.org/",
  "author": "Ghost Foundation",
  "license": "MIT",
  "main": "index.js",
  "packageManager": "pnpm@10.34.4",
  "scripts": {
    "lint": "oxlint --quiet && oxfmt --check .",
    "lint:fix": "oxlint --fix && oxfmt .",
    "format": "oxfmt .",
    "test": "vitest run --coverage",
    "test:e2e": "./test-e2e/run.sh",
    "test:e2e:bare": "vitest run --config vitest.e2e.config.js",
    "ship": "pro-ship"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@tryghost/admin-api": "1.14.10",
    "lodash": "4.18.1",
    "semver": "7.8.5",
    "zapier-platform-core": "19.0.0"
  },
  "devDependencies": {
    "@tryghost/pro-ship": "1.1.5",
    "@vitest/coverage-v8": "4.1.9",
    "nock": "14.0.16",
    "oxfmt": "0.57.0",
    "oxlint": "1.72.0",
    "vitest": "4.1.9",
    "zapier-platform-cli": "19.0.0"
  },
  "pnpm": {
    "overrides": {
      "form-data@<4.0.6": ">=4.0.6"
    }
  }
}
